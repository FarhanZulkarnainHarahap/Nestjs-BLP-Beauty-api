{
  "name": "beauty-nest-bun-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start:dev": "bun --watch src/main.ts",
    "start": "bun src/main.ts",
    "build": "nest build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deploy": "npx --yes vercel@latest",
    "deploy:prod": "npx --yes vercel@latest --prod",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "bun prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.8",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.8",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-express": "^11.1.8",
    "@prisma/client": "^6.19.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cloudinary": "^2.8.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.10.1",
    "prettier": "^3.9.4",
    "prisma": "^6.19.0",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "seed": "bun prisma/seed.ts"
  },
  "overrides": {
    "multer": "^2.2.0"
  }
}
